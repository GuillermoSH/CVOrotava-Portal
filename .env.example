# Copy to `.env.local` and fill from Supabase project settings (never commit `.env.local`).

# Public — safe to expose in browser bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never use in Client Components or `NEXT_PUBLIC_*`
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — avisos por correo (p. ej. Resend) desde el servidor
# RESEND_API_KEY=
